#!/usr/bin/env python3
"""Review a PR, optionally approve + auto-merge, or request Dependabot rebase."""

from __future__ import annotations

import shutil
import subprocess
import sys
from typing import Iterable

USAGE = "Usage: gh auto-pr-review <PR_NUMBER_OR_URL>"


def fail(message: str, exit_code: int = 1) -> None:
    print(message, file=sys.stderr)
    raise SystemExit(exit_code)


def run_gh(
    args: list[str], *, capture_stdout: bool = False
) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        ["gh", *args],
        check=True,
        text=True,
        stdout=subprocess.PIPE if capture_stdout else None,
    )


def print_filtered_diff(pr_ref: str) -> None:
    result = run_gh(
        ["pr", "diff", pr_ref, "--color", "always", "--exclude", "pnpm-lock.yaml"],
        capture_stdout=True,
    )

    for line in result.stdout.splitlines(keepends=True):
        print(line, end="")


def is_yes(answer: str) -> bool:
    lowered = answer.strip().lower()
    return lowered in {"y", "yes"}


def is_rebase(answer: str) -> bool:
    return answer.strip().lower() == "r"


def main(argv: Iterable[str]) -> int:
    if shutil.which("gh") is None:
        fail("Error: gh CLI not found in PATH.")

    args = list(argv)
    if len(args) != 1:
        fail(USAGE)

    pr_ref = args[0]

    try:
        pr_url = run_gh(
            ["pr", "view", pr_ref, "--json", "url", "--jq", ".url"], capture_stdout=True
        ).stdout.strip()
    except subprocess.CalledProcessError as exc:
        fail(
            f"Error: could not resolve PR '{pr_ref}' (gh exited with {exc.returncode})."
        )

    if not pr_url:
        fail(f"Error: could not resolve PR '{pr_ref}'.")

    print(f"PR: {pr_url}\n")
    print("Diff (excluding pnpm-lock.yaml):\n")

    try:
        print_filtered_diff(pr_ref)
    except subprocess.CalledProcessError as exc:
        fail(f"Error: failed to fetch PR diff (gh exited with {exc.returncode}).")

    print()
    answer = input("Approve PR ([y]es / [r]ebase / [N]o)? ")

    try:
        if is_yes(answer):
            print("Approving PR...")
            run_gh(["pr", "review", pr_ref, "--approve"])

            print("Enabling auto-merge...")
            run_gh(["pr", "merge", pr_ref, "-m", "--auto"])

            print("PR approved and set to auto-merge.")
        elif is_rebase(answer):
            print("Requesting Dependabot rebase...")
            run_gh(["pr", "comment", pr_ref, "--body", "@dependabot rebase"])
            print("Posted rebase comment.")
        else:
            print("Approval skipped.")
    except subprocess.CalledProcessError as exc:
        fail(f"Error: gh command failed (exit {exc.returncode}).")

    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
